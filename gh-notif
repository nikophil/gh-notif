#!/usr/bin/env node
import { existsSync } from 'node:fs';
import readline from 'node:readline';
import { makeGh } from './src/github.js';
import { collectPRs } from './src/collect.js';
import { CATEGORY } from './src/filter.js';
import { diffApprovals } from './src/approvals.js';
import { renderList, renderDebugText } from './src/render.js';
import { sendNotification, watchEventLine } from './src/notify.js';
import { statePath, loadState, saveState, isNew, markSeen } from './src/state.js';
import { startSpinner } from './src/spinner.js';
import { hiddenPath, loadHidden, saveHidden, toggleHidden, assignLabels, isHidden, keyOf } from './src/hidden.js';
import { serve } from './src/serve.js';
import { isRateLimitError, nextBackoffSeconds } from './src/ratelimit.js';

const POLL_SECONDS = 60;
const BACKOFF_CAP = 600; // plafond du recul en cas de rate-limit (10 min)
const sleep = (s) => new Promise((r) => setTimeout(r, s * 1000));
const now = () => new Date().toLocaleTimeString('fr-FR');

// Interactivité seulement en vrai terminal (stdin ET stdout TTY) : en
// pipe/redirection, on garde le comportement « affiche puis rend la main ».
const interactive = () => process.stdin.isTTY && process.stdout.isTTY;

// Lignes « autres » à afficher (+ flags masqué) selon le mode courant. La
// sélection se fait au numéro de PR (colonne « PR »), pas à un index.
function viewModel(data, { showHidden }) {
  const rows = showHidden ? [...data.others, ...data.hidden] : data.others;
  const hiddenFlags = showHidden
    ? [...data.others.map(() => false), ...data.hidden.map(() => true)]
    : data.others.map(() => false);
  return { rows, hiddenFlags };
}

// Re-filtre others/hidden depuis les données déjà en mémoire (pas de refetch)
// après un toggle interactif.
function recompute(data, hidden) {
  const all = [...data.others, ...data.hidden];
  const others = all.filter((r) => !isHidden(hidden, keyOf(r)));
  const hiddenRows = all.filter((r) => isHidden(hidden, keyOf(r)));
  return { ...data, others, hidden: hiddenRows, hiddenCount: hiddenRows.length };
}

// Index de la ligne dont le numéro de PR == saisie (1re occurrence), ou -1.
function rowIndexForInput(rows, buffer) {
  return assignLabels(rows).indexOf(buffer.replace(/^#/, ''));
}

// Bandeau d'aide sous les tableaux. En mode masquage : invite « # de la PR ».
// `quitHint` ajoute la touche de sortie propre au contexte (q en one-shot).
function helpBanner(hideMode, buffer, quitHint = '') {
  return hideMode
    ? `\n\x1b[2mn° de la PR à masquer/restaurer : \x1b[0m#${buffer}\x1b[2m_  ·  Entrée valide · Esc annule\x1b[0m\n`
    : `\n\x1b[2m↳ appuie sur \x1b[0mh\x1b[2m pour masquer/restaurer une PR des autres${quitHint}\x1b[0m\n`;
}

// Ligne de journal (--watch -v) quand une PR est masquée/restaurée à la main.
function hideEventLine(nowHidden, row, time) {
  const what = nowHidden ? '🙈 PR masquée' : '👁  PR restaurée';
  return `\x1b[2m${time}\x1b[0m  ${what}  ·  ${row.repo} #${row.number} ${row.title}`;
}

// Boucle clavier partagée (one-shot). Résout quand l'utilisateur quitte (q hors
// mode masquage). `draw(hideMode, buffer)` redessine ; `rowsFor()` renvoie les
// lignes « autres » courantes ; `onToggle(row)` masque/restaure. On quitte le
// mode masquage dès qu'une PR a été (dé)masquée.
function runInteractive({ draw, rowsFor, onToggle }) {
  return new Promise((resolve) => {
    let hideMode = false;
    let buffer = ''; // chiffres du numéro de PR saisi en mode masquage
    readline.emitKeypressEvents(process.stdin);
    process.stdin.setRawMode(true);
    process.stdin.resume();
    const cleanup = () => {
      try { process.stdin.setRawMode(false); } catch {}
      process.stdin.pause();
      process.stdin.removeListener('keypress', onKey);
    };
    const onKey = (str, key) => {
      if (key.ctrl && key.name === 'c') { cleanup(); process.stdout.write('\n'); resolve(); return; }
      if (!hideMode) {
        if (str === 'h') { hideMode = true; buffer = ''; draw(true, buffer); }
        else if (str === 'q') { cleanup(); resolve(); }
        return;
      }
      // mode masquage : buffer du n° de PR, Entrée valide, Backspace efface, Esc annule
      if (key.name === 'escape') { hideMode = false; buffer = ''; draw(false, ''); return; }
      if (key.name === 'return' || key.name === 'enter') {
        const rows = rowsFor();
        const idx = rowIndexForInput(rows, buffer);
        if (idx >= 0) {
          onToggle(rows[idx]);
          hideMode = false; buffer = ''; draw(false, ''); // sortie auto après action
        } else {
          buffer = ''; draw(true, buffer); // numéro inconnu : on réinitialise la saisie
        }
        return;
      }
      if (key.name === 'backspace') { buffer = buffer.slice(0, -1); draw(true, buffer); return; }
      if (str && /[0-9]/.test(str)) { buffer += str; draw(true, buffer); }
    };
    process.stdin.on('keypress', onKey);
    draw(false, '');
  });
}


const RECENT_MAX = 8; // évènements de session affichés sous les tableaux

async function runWatch(gh, { scope, verbose, showHidden, debug, intervalSeconds = POLL_SECONDS }) {
  const me = await gh.getCurrentUser();
  const path = statePath();
  const hiddenFile = hiddenPath();
  const hidden = loadHidden(hiddenFile);
  let primed = existsSync(path); // un état existe déjà : on notifie normalement
  const state = loadState(path);
  const recent = []; // lignes d'évènements (plus récent en tête)
  const inspectCache = new Map(); // thread inchangé entre polls = 0 requête
  const seenApprovals = new Set(); // approbations déjà vues (par process)
  let primedApprovals = false; // 1er poll = amorçage silencieux
  let backoff = 0; // secondes ajoutées à l'intervalle après un rate-limit
  let data = null;
  let hideMode = false;
  let buffer = '';

  // Redessine : en-tête + les deux tableaux + bandeau (indice ou saisie) + journal.
  const redraw = () => {
    if (!data) return;
    const vm = viewModel(data, { showHidden });
    if (process.stdout.isTTY) process.stdout.write('\x1b[2J\x1b[3J\x1b[H');
    process.stdout.write(`\x1b[2m🔄 gh notif --watch · maj ${now()} · toutes les ${intervalSeconds}s · Ctrl-C pour arrêter\x1b[0m\n\n`);
    process.stdout.write(renderList({ mine: data.mine, others: vm.rows, hiddenCount: data.hiddenCount },
      { showHidden, hiddenFlags: vm.hiddenFlags }));
    // indice « h » en permanence (mode normal) ou invite de saisie (mode masquage)
    if (interactive()) process.stdout.write(helpBanner(hideMode, buffer));
    if (verbose && recent.length > 0) {
      process.stdout.write(`\n\x1b[1m🔔 Évènements détectés (session)\x1b[0m\n`);
      for (const line of recent) process.stdout.write(`${line}\n`);
    }
    if (debug) process.stdout.write(`\n${renderDebugText(data.debug)}`);
  };

  if (interactive()) {
    readline.emitKeypressEvents(process.stdin);
    process.stdin.setRawMode(true);
    process.stdin.on('keypress', (str, key) => {
      if (key.ctrl && key.name === 'c') { try { process.stdin.setRawMode(false); } catch {} process.stdout.write('\n'); process.exit(0); }
      if (!hideMode) { if (str === 'h' && data) { hideMode = true; buffer = ''; redraw(); } return; }
      if (key.name === 'escape') { hideMode = false; buffer = ''; redraw(); return; }
      if (key.name === 'return' || key.name === 'enter') {
        const rows = viewModel(data, { showHidden }).rows;
        const idx = rowIndexForInput(rows, buffer);
        if (idx >= 0) {
          const row = rows[idx];
          const nowHidden = toggleHidden(hidden, keyOf(row), data.notifications);
          saveHidden(hiddenFile, hidden);
          data = recompute(data, hidden);
          recent.unshift(hideEventLine(nowHidden, row, now())); // journal (-v)
          while (recent.length > RECENT_MAX) recent.pop();
          hideMode = false; // sortie auto après action
        }
        buffer = ''; redraw(); return;
      }
      if (key.name === 'backspace') { buffer = buffer.slice(0, -1); redraw(); return; }
      if (str && /[0-9]/.test(str)) { buffer += str; redraw(); }
    });
  }

  // Attente paçant les polls. Gelée pendant le mode masquage (ni écriture ni
  // décompte) pour ne pas écraser l'écran sous l'utilisateur.
  const waitNextPoll = async () => {
    const total = intervalSeconds + backoff; // recul en cas de rate-limit
    for (let n = total; n > 0; ) {
      if (hideMode) { await sleep(0.2); continue; }
      if (process.stdout.isTTY) process.stdout.write(`\r\x1b[2m⏳ prochain check dans ${String(n).padStart(2)}s…\x1b[0m\x1b[K`);
      await sleep(1);
      n--;
    }
    if (process.stdout.isTTY) process.stdout.write('\r\x1b[K');
  };

  for (;;) {
    if (!hideMode) {
      try {
        const stop = startSpinner('Mise à jour…');
        try {
          data = await collectPRs(gh, me, { all: false, scope, hidden, cache: inspectCache });
        } finally {
          stop();
        }
        backoff = 0; // succès : on repart à l'intervalle normal
        if (data.hiddenChanged) saveHidden(hiddenFile, hidden);
        // Approbations sur mes PR (hors threads de notif) : amorçage silencieux au
        // 1er poll, puis notif desktop + journal (-v) sur chaque nouvel approve.
        const freshApprovals = diffApprovals({ events: data.approvalEvents ?? [], seen: seenApprovals, primed: primedApprovals });
        primedApprovals = true;
        for (const e of freshApprovals) {
          const item = { ...e, category: CATEGORY.APPROVAL };
          sendNotification(item);
          recent.unshift(watchEventLine(item, now(), { hyperlinks: process.stdout.isTTY }));
        }
        const items = data.notifications ?? [];
        if (!primed) {
          // Premier run : on enregistre le backlog existant sans alerter,
          // pour ne notifier que les évènements survenant après le démarrage.
          for (const item of items) markSeen(state, item);
          saveState(path, state);
          primed = true;
        } else {
          // PR encore ouvertes/pending (visibles, masquées ou miennes) : sert à ne pas
          // notifier une demande de review sur une PR déjà fermée/mergée (cf. #7004).
          // On inclut data.hidden : une PR masquée reste « ouverte ».
          const openKeys = new Set([...data.mine, ...data.others, ...data.hidden].map((r) => `${r.repo}#${r.number}`));
          const fresh = items.filter((i) => isNew(state, i));
          for (const item of fresh) {
            markSeen(state, item);
            // une demande de review n'a de sens que sur une PR ouverte
            if (item.category === CATEGORY.REVIEW_REQUEST && !openKeys.has(`${item.repo}#${item.number}`)) continue;
            sendNotification(item);
            recent.unshift(watchEventLine(item, now(), { hyperlinks: process.stdout.isTTY }));
          }
          if (fresh.length > 0) saveState(path, state);
        }
        while (recent.length > RECENT_MAX) recent.pop();
        redraw();
      } catch (err) {
        if (isRateLimitError(err.message)) {
          backoff = nextBackoffSeconds(backoff, intervalSeconds, BACKOFF_CAP);
          const msg = `⏳ rate-limité par GitHub — reprise dans ${intervalSeconds + backoff}s`;
          if (verbose) {
            recent.unshift(`\x1b[2m${now()}\x1b[0m  ${msg}`);
            while (recent.length > RECENT_MAX) recent.pop();
            redraw();
          } else {
            process.stderr.write(`gh notif --watch: ${msg}\n`);
          }
        } else {
          process.stderr.write(`gh notif --watch: ${err.message}\n`);
        }
      }
    }
    await waitNextPoll();
  }
}

const HELP = `gh notif — notifications GitHub filtrées

Usage:
  gh notif                   Deux tableaux : tes PR / les PR des autres
  gh notif --all             Inclut les notifications déjà lues
  gh notif --watch           Tableaux rafraîchis en continu + notifs desktop
  gh notif --watch -v        + journal des évènements détectés sous les tableaux
  gh notif --serve [--port N]  Page web locale auto-rafraîchie (défaut :7777)
  gh notif --interval N      Secondes entre deux polls (--watch/--serve, plancher 60)
  gh notif --org <org>       Limite à une organisation
  gh notif --repo [o/r]      Limite à un dépôt (sans valeur = dépôt courant)
  gh notif --show-hidden     Affiche aussi les PR masquées (grisées, 🙈)
  gh notif --debug           Dump du verdict de classification par thread (terminal)
  gh notif --help            Affiche cette aide

--org et --repo sont mutuellement exclusifs. Ils s'appliquent aussi à --watch.

Touches (terminal interactif) : h = masquer/restaurer une PR des autres ·
(en mode masquage) n° de PR + Entrée = valider · Esc = annuler · q = quitter.
`;

// Parse les arguments. repo: undefined=absent, null=donné sans valeur (dépôt
// courant), string=valeur. org: undefined=absent, null=donné sans valeur
// (erreur, valeur requise), string=valeur.
function parseArgs(argv) {
  const args = argv.slice(2);
  const flags = { all: false, watch: false, serve: false, port: undefined, interval: undefined, help: false, verbose: false, debug: false, showHidden: false, org: undefined, repo: undefined };
  for (let i = 0; i < args.length; i++) {
    const a = args[i];
    const takeValue = () => {
      const next = args[i + 1];
      if (next && !next.startsWith('-')) { i += 1; return next; }
      return null;
    };
    if (a === '--help' || a === '-h') flags.help = true;
    else if (a === '--all') flags.all = true;
    else if (a === '--watch') flags.watch = true;
    else if (a === '--serve') flags.serve = true;
    else if (a.startsWith('--port=')) flags.port = Number(a.slice(7));
    else if (a === '--port') { const v = takeValue(); flags.port = v === null ? null : Number(v); }
    else if (a.startsWith('--interval=')) flags.interval = Number(a.slice(11));
    else if (a === '--interval') { const v = takeValue(); flags.interval = v === null ? null : Number(v); }
    else if (a === '--verbose' || a === '-v') flags.verbose = true;
    else if (a === '--debug') flags.debug = true;
    else if (a === '--show-hidden') flags.showHidden = true;
    else if (a.startsWith('--org=')) flags.org = a.slice(6);
    else if (a === '--org') flags.org = takeValue();
    else if (a.startsWith('--repo=')) flags.repo = a.slice(7);
    else if (a === '--repo') flags.repo = takeValue();
  }
  return flags;
}

// Intervalle de poll effectif : plancher GitHub à 60 s. Une valeur fournie plus
// basse est ramenée à 60 (message informatif sur stderr).
function effectiveInterval(flags) {
  if (flags.interval === undefined) return POLL_SECONDS;
  if (!Number.isInteger(flags.interval)) {
    throw new Error('--interval requiert un entier (secondes, ex. --interval 120)');
  }
  if (flags.interval < POLL_SECONDS) {
    process.stderr.write(`gh notif: --interval ${flags.interval}s sous le plancher GitHub, ramené à ${POLL_SECONDS}s\n`);
    return POLL_SECONDS;
  }
  return flags.interval;
}

async function resolveScope(gh, flags) {
  if (flags.org !== undefined && flags.repo !== undefined) {
    throw new Error('--org et --repo sont mutuellement exclusifs');
  }
  if (flags.org !== undefined) {
    if (!flags.org) throw new Error('--org requiert une valeur (ex. --org mapado)');
    return { type: 'org', value: flags.org };
  }
  if (flags.repo !== undefined) {
    const value = flags.repo ?? (await gh.currentRepo());
    if (!value) throw new Error('--repo sans valeur : impossible de déterminer le dépôt courant (pas dans un dépôt git ?)');
    return { type: 'repo', value };
  }
  return null;
}

async function runList(gh, { all, scope, showHidden, debug }) {
  const hiddenFile = hiddenPath();
  const hidden = loadHidden(hiddenFile);
  const stop = startSpinner('Récupération des PRs et notifications…');
  let data;
  try {
    const me = await gh.getCurrentUser();
    data = await collectPRs(gh, me, { all, scope, hidden });
  } finally {
    stop();
  }
  if (data.hiddenChanged) saveHidden(hiddenFile, hidden);

  // Hors TTY (pipe/redirection) : affiche puis rend la main, sans interaction.
  if (!interactive()) {
    const vm = viewModel(data, { showHidden });
    process.stdout.write(renderList({ mine: data.mine, others: vm.rows, hiddenCount: data.hiddenCount },
      { showHidden, hiddenFlags: vm.hiddenFlags }));
    if (debug) process.stdout.write(`\n${renderDebugText(data.debug)}`);
    return;
  }

  // Terminal interactif : on reste vivant pour permettre le masquage au clavier.
  await runInteractive({
    draw: (hideMode, buffer) => {
      const vm = viewModel(data, { showHidden });
      process.stdout.write('\x1b[2J\x1b[3J\x1b[H');
      process.stdout.write(renderList({ mine: data.mine, others: vm.rows, hiddenCount: data.hiddenCount },
        { showHidden, hiddenFlags: vm.hiddenFlags }));
      process.stdout.write(helpBanner(hideMode, buffer, ' · q pour quitter'));
      if (debug) process.stdout.write(`\n${renderDebugText(data.debug)}`);
    },
    rowsFor: () => viewModel(data, { showHidden }).rows,
    onToggle: (row) => { toggleHidden(hidden, keyOf(row), data.notifications); saveHidden(hiddenFile, hidden); data = recompute(data, hidden); },
  });
}

async function main(argv) {
  const flags = parseArgs(argv);
  if (flags.help) { process.stdout.write(HELP); return; }
  const gh = makeGh();
  try {
    const scope = await resolveScope(gh, flags);
    const intervalSeconds = effectiveInterval(flags);
    if (flags.serve) {
      if (flags.port !== undefined && flags.port !== null && !Number.isInteger(flags.port)) {
        throw new Error('--port requiert un entier (ex. --port 7777)');
      }
      const me = await gh.getCurrentUser();
      serve({ gh, me, scope, all: flags.all, port: flags.port ?? 7777, intervalSeconds });
    } else if (flags.watch) {
      await runWatch(gh, { scope, verbose: flags.verbose, showHidden: flags.showHidden, debug: flags.debug, intervalSeconds });
    } else {
      await runList(gh, { all: flags.all, scope, showHidden: flags.showHidden, debug: flags.debug });
    }
  } catch (err) {
    process.stderr.write(`gh notif: ${err.message}\n`);
    process.exit(1);
  }
}

main(process.argv);

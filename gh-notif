#!/usr/bin/env node
import { existsSync } from 'node:fs';
import readline from 'node:readline';
import { makeGh } from './src/github.js';
import { collectPRs } from './src/collect.js';
import { CATEGORY } from './src/filter.js';
import { diffApprovals } from './src/approvals.js';
import { renderList, renderDebugText, favoritesBar } from './src/render.js';
import { prefsPath, loadPrefs, savePrefs, ignoredChecksOf } from './src/prefs.js';
import {
  parseScope, normalizeFavorites, addFavorite, removeFavorite,
  favoriteScopes, activeFavoriteOf, cycleFavorite, filterDataByScope,
} from './src/favorites.js';
import { sendNotification, watchEventLine } from './src/notify.js';
import { statePath, loadState, saveState, isNew, markSeen } from './src/state.js';
import { startSpinner } from './src/spinner.js';
import { hiddenPath, loadHidden, saveHidden, toggleHidden, assignLabels, isHidden, keyOf } from './src/hidden.js';
import { serve } from './src/serve.js';
import { isRateLimitError, nextBackoffSeconds } from './src/ratelimit.js';

const POLL_SECONDS = 60;
const BACKOFF_CAP = 600; // backoff ceiling in case of rate-limit (10 min)
const sleep = (s) => new Promise((r) => setTimeout(r, s * 1000));
const now = () => new Date().toLocaleTimeString('en-US');

// Interactivity only in a real terminal (stdin AND stdout TTY): in
// pipe/redirection, we keep the "print then hand back control" behavior.
const interactive = () => process.stdin.isTTY && process.stdout.isTTY;

// "Others" rows to display (+ hidden flags) according to the current mode. The
// selection is done by PR number (the "PR" column), not by an index.
function viewModel(data, { showHidden }) {
  const rows = showHidden ? [...data.others, ...data.hidden] : data.others;
  const hiddenFlags = showHidden
    ? [...data.others.map(() => false), ...data.hidden.map(() => true)]
    : data.others.map(() => false);
  return { rows, hiddenFlags };
}

// Re-filter others/hidden from the data already in memory (no refetch)
// after an interactive toggle.
function recompute(data, hidden) {
  const all = [...data.others, ...data.hidden];
  const others = all.filter((r) => !isHidden(hidden, keyOf(r)));
  const hiddenRows = all.filter((r) => isHidden(hidden, keyOf(r)));
  return { ...data, others, hidden: hiddenRows, hiddenCount: hiddenRows.length };
}

// Index of the row whose PR number == input (1st occurrence), or -1.
function rowIndexForInput(rows, buffer) {
  return assignLabels(rows).indexOf(buffer.replace(/^#/, ''));
}

// Help banner under the tables. In hide mode: prompts for "PR #".
// `quitHint` adds the context-specific exit key (q in one-shot).
// `favBar` (favorites bar) is displayed above, only if favorites
// exist — and the "f" hint appears only in that case.
function helpBanner(hideMode, buffer, quitHint = '', favBar = '') {
  const bar = favBar ? `\n${favBar}\n` : '';
  if (hideMode) {
    return `${bar}\n\x1b[2mPR # to hide/restore: \x1b[0m#${buffer}\x1b[2m_  ·  Enter confirms · Esc cancels\x1b[0m\n`;
  }
  const favHint = favBar ? `\x1b[0mf\x1b[2m to switch favorite · \x1b[0m` : '';
  return `${bar}\n\x1b[2m↳ ${favHint}\x1b[2mpress \x1b[0mh\x1b[2m to hide/restore one of the others' PRs${quitHint}\x1b[0m\n`;
}

// Log line (--watch -v) when a PR is hidden/restored by hand.
function hideEventLine(nowHidden, row, time) {
  const what = nowHidden ? '🙈 PR hidden' : '👁  PR restored';
  return `\x1b[2m${time}\x1b[0m  ${what}  ·  ${row.repo} #${row.number} ${row.title}`;
}

// Shared keyboard loop (one-shot). Resolves when the user quits (q outside
// hide mode). `draw(hideMode, buffer)` redraws; `rowsFor()` returns the
// current "others" rows; `onToggle(row)` hides/restores;
// `onCycleFav()` moves to the next favorite (local filter, no request). We leave
// hide mode as soon as a PR has been (un)hidden.
function runInteractive({ draw, rowsFor, onToggle, onCycleFav }) {
  return new Promise((resolve) => {
    let hideMode = false;
    let buffer = ''; // digits of the PR number typed in hide mode
    readline.emitKeypressEvents(process.stdin);
    process.stdin.setRawMode(true);
    process.stdin.resume();
    const cleanup = () => {
      try { process.stdin.setRawMode(false); } catch {}
      process.stdin.pause();
      process.stdin.removeListener('keypress', onKey);
    };
    const onKey = (str, key) => {
      if (key.ctrl && key.name === 'c') { cleanup(); process.stdout.write('\n'); resolve(); return; }
      if (!hideMode) {
        if (str === 'h') { hideMode = true; buffer = ''; draw(true, buffer); }
        // `f` outside hide mode only: in hide mode, the input is
        // numeric and `f` must not steal the keystroke.
        else if (str === 'f' && onCycleFav) { onCycleFav(); draw(false, ''); }
        else if (str === 'q') { cleanup(); resolve(); }
        return;
      }
      // hide mode: buffer of the PR #, Enter confirms, Backspace deletes, Esc cancels
      if (key.name === 'escape') { hideMode = false; buffer = ''; draw(false, ''); return; }
      if (key.name === 'return' || key.name === 'enter') {
        const rows = rowsFor();
        const idx = rowIndexForInput(rows, buffer);
        if (idx >= 0) {
          onToggle(rows[idx]);
          hideMode = false; buffer = ''; draw(false, ''); // auto-exit after action
        } else {
          buffer = ''; draw(true, buffer); // unknown number: reset the input
        }
        return;
      }
      if (key.name === 'backspace') { buffer = buffer.slice(0, -1); draw(true, buffer); return; }
      if (str && /[0-9]/.test(str)) { buffer += str; draw(true, buffer); }
    };
    process.stdin.on('keypress', onKey);
    draw(false, '');
  });
}


const RECENT_MAX = 8; // session events displayed under the tables

async function runWatch(gh, { scope, verbose, showHidden, debug, intervalSeconds = POLL_SECONDS, favorites = [], activeFav = null, prefs = null, prefsFile = null }) {
  const me = await gh.getCurrentUser();
  const ignoredChecks = ignoredChecksOf(prefs); // CI blocklist per repo (verdict recomputation)
  const path = statePath();
  const hiddenFile = hiddenPath();
  const hidden = loadHidden(hiddenFile);
  let primed = existsSync(path); // a state already exists: we notify normally
  const state = loadState(path);
  const recent = []; // event lines (most recent first)
  const inspectCache = new Map(); // thread unchanged between polls = 0 request
  const seenApprovals = new Set(); // approvals already seen (per process)
  let primedApprovals = false; // 1st poll = silent priming
  let backoff = 0; // seconds added to the interval after a rate-limit
  let data = null;
  let hideMode = false;
  let buffer = '';
  // `data` stays raw (union of favorites): the desktop notifs cover ALL the
  // favorites, including those we're not looking at. `view()` filters at display time.
  let current = activeFav;
  const view = () => filterDataByScope(data, parseScope(current));

  // Redraws: header + the two tables + banner (hint or input) + log.
  const redraw = () => {
    if (!data) return;
    const shown = view();
    const vm = viewModel(shown, { showHidden });
    if (process.stdout.isTTY) process.stdout.write('\x1b[2J\x1b[3J\x1b[H');
    process.stdout.write(`\x1b[2m🔄 gh notif --watch · upd ${now()} · every ${intervalSeconds}s · Ctrl-C to stop\x1b[0m\n\n`);
    process.stdout.write(renderList({ mine: shown.mine, others: vm.rows, hiddenCount: shown.hiddenCount },
      { showHidden, hiddenFlags: vm.hiddenFlags }));
    // "h" hint permanently (normal mode) or input prompt (hide mode)
    if (interactive()) process.stdout.write(helpBanner(hideMode, buffer, '', favoritesBar(favorites, current)));
    if (verbose && recent.length > 0) {
      process.stdout.write(`\n\x1b[1m🔔 Detected events (session)\x1b[0m\n`);
      for (const line of recent) process.stdout.write(`${line}\n`);
    }
    if (debug) process.stdout.write(`\n${renderDebugText(shown.debug, { rows: debugRows(shown), ignoredChecks })}`);
  };

  if (interactive()) {
    readline.emitKeypressEvents(process.stdin);
    process.stdin.setRawMode(true);
    process.stdin.on('keypress', (str, key) => {
      if (key.ctrl && key.name === 'c') { try { process.stdin.setRawMode(false); } catch {} process.stdout.write('\n'); process.exit(0); }
      if (!hideMode) {
        if (str === 'h' && data) { hideMode = true; buffer = ''; redraw(); }
        // Switching favorite = local filter: no poll, no loop freeze.
        else if (str === 'f' && favorites.length > 0) {
          current = cycleFavorite(favorites, current);
          if (prefs && prefsFile) { prefs.activeFav = current; savePrefs(prefsFile, prefs); }
          redraw();
        }
        return;
      }
      if (key.name === 'escape') { hideMode = false; buffer = ''; redraw(); return; }
      if (key.name === 'return' || key.name === 'enter') {
        const rows = viewModel(view(), { showHidden }).rows;
        const idx = rowIndexForInput(rows, buffer);
        if (idx >= 0) {
          const row = rows[idx];
          const nowHidden = toggleHidden(hidden, keyOf(row), data.notifications);
          saveHidden(hiddenFile, hidden);
          data = recompute(data, hidden);
          recent.unshift(hideEventLine(nowHidden, row, now())); // log (-v)
          while (recent.length > RECENT_MAX) recent.pop();
          hideMode = false; // auto-exit after action
        }
        buffer = ''; redraw(); return;
      }
      if (key.name === 'backspace') { buffer = buffer.slice(0, -1); redraw(); return; }
      if (str && /[0-9]/.test(str)) { buffer += str; redraw(); }
    });
  }

  // Wait spacing out the polls. Frozen during hide mode (no writing nor
  // countdown) so as not to overwrite the screen under the user.
  const waitNextPoll = async () => {
    const total = intervalSeconds + backoff; // backoff in case of rate-limit
    for (let n = total; n > 0; ) {
      if (hideMode) { await sleep(0.2); continue; }
      if (process.stdout.isTTY) process.stdout.write(`\r\x1b[2m⏳ next check in ${String(n).padStart(2)}s…\x1b[0m\x1b[K`);
      await sleep(1);
      n--;
    }
    if (process.stdout.isTTY) process.stdout.write('\r\x1b[K');
  };

  for (;;) {
    if (!hideMode) {
      try {
        const stop = startSpinner('Updating…');
        try {
          data = await collectPRs(gh, me, { all: false, scope, hidden, cache: inspectCache, ignoredChecks });
        } finally {
          stop();
        }
        backoff = 0; // success: back to the normal interval
        if (data.hiddenChanged) saveHidden(hiddenFile, hidden);
        // Approvals on my PRs (outside notif threads): silent priming on the
        // 1st poll, then desktop notif + log (-v) on each new approve.
        const freshApprovals = diffApprovals({ events: data.approvalEvents ?? [], seen: seenApprovals, primed: primedApprovals });
        primedApprovals = true;
        for (const e of freshApprovals) {
          const item = { ...e, category: CATEGORY.APPROVAL };
          sendNotification(item);
          recent.unshift(watchEventLine(item, now(), { hyperlinks: process.stdout.isTTY }));
        }
        const items = data.notifications ?? [];
        if (!primed) {
          // First run: we record the existing backlog without alerting,
          // to only notify events occurring after startup.
          for (const item of items) markSeen(state, item);
          saveState(path, state);
          primed = true;
        } else {
          // PRs still open/pending (visible, hidden or mine): used to avoid
          // notifying a review request on a PR already closed/merged (cf. #7004).
          // We include data.hidden: a hidden PR stays "open".
          const openKeys = new Set([...data.mine, ...data.others, ...data.hidden].map((r) => `${r.repo}#${r.number}`));
          const fresh = items.filter((i) => isNew(state, i));
          for (const item of fresh) {
            markSeen(state, item);
            // a review request only makes sense on an open PR
            if (item.category === CATEGORY.REVIEW_REQUEST && !openKeys.has(`${item.repo}#${item.number}`)) continue;
            sendNotification(item);
            recent.unshift(watchEventLine(item, now(), { hyperlinks: process.stdout.isTTY }));
          }
          if (fresh.length > 0) saveState(path, state);
        }
        while (recent.length > RECENT_MAX) recent.pop();
        redraw();
      } catch (err) {
        if (isRateLimitError(err.message)) {
          backoff = nextBackoffSeconds(backoff, intervalSeconds, BACKOFF_CAP);
          const msg = `⏳ rate-limited by GitHub — retrying in ${intervalSeconds + backoff}s`;
          if (verbose) {
            recent.unshift(`\x1b[2m${now()}\x1b[0m  ${msg}`);
            while (recent.length > RECENT_MAX) recent.pop();
            redraw();
          } else {
            process.stderr.write(`gh notif --watch: ${msg}\n`);
          }
        } else {
          process.stderr.write(`gh notif --watch: ${err.message}\n`);
        }
      }
    }
    await waitNextPoll();
  }
}

const HELP = `gh notif — filtered GitHub notifications

Usage:
  gh notif                   Two tables: your PRs / others' PRs
  gh notif --all             Includes already-read notifications
  gh notif --watch           Continuously refreshed tables + desktop notifs
  gh notif --watch -v        + log of detected events below the tables
  gh notif --serve [--port N]  Local auto-refreshing web page (default :7777)
  gh notif --serve --no-open   Without opening the browser (URL stays printed)
  gh notif --interval N      Seconds between two polls (--watch/--serve, floor 60)
  gh notif --org <org>       Limit to one organization
  gh notif --repo [o/r]      Limit to one repository (no value = current repo)
  gh notif --fav <scope>     Start on this favorite (must be in the list)
  gh notif --show-hidden     Also show hidden PRs (greyed out, 🙈)
  gh notif --debug           Dump the classification verdict per thread (terminal)
  gh notif --help            Show this help

Favorites (pinned scopes) :
  gh notif fav list          List favorites (⭐ = the one shown)
  gh notif fav add <scope>   Pin an org (mapado) or a repository (owner/repo)
  gh notif fav rm <scope>    Remove a favorite

As soon as a favorite exists, collection covers the UNION of favorites — so the
desktop notifications of all of them arrive continuously — and only the active
favorite is shown. Switching favorite costs no GitHub request.

--org and --repo are mutually exclusive. They also apply to --watch and take
precedence over favorites (then ignored).

Keys (interactive terminal): f = next favorite · h = hide/restore one of the
others' PRs · (in hide mode) PR # + Enter = confirm · Esc = cancel ·
q = quit.

Ignored CI jobs: so that an unimportant job (e.g. a label reminder) no longer
turns a PR to ❌, add it to the repo blocklist in prefs-v1.json :
  "ignoredChecks": { "owner/repo": ["exact check name"] }
The CI verdict is then recomputed without that job. The EXACT check name is copied
from the « Checks by repo » section of --debug mode (or the /debug page in --serve).
In --serve, that section is interactive: check/uncheck a job to ignore it without
editing the file (the verdict updates with no GitHub call).
`;

// Parse the arguments. repo: undefined=absent, null=given without value (current
// repo), string=value. org: undefined=absent, null=given without value
// (error, value required), string=value.
function parseArgs(argv) {
  const args = argv.slice(2);
  const flags = { all: false, watch: false, serve: false, port: undefined, interval: undefined, help: false, verbose: false, debug: false, showHidden: false, org: undefined, repo: undefined, fav: undefined, noOpen: false };
  for (let i = 0; i < args.length; i++) {
    const a = args[i];
    const takeValue = () => {
      const next = args[i + 1];
      if (next && !next.startsWith('-')) { i += 1; return next; }
      return null;
    };
    if (a === '--help' || a === '-h') flags.help = true;
    else if (a === '--all') flags.all = true;
    else if (a === '--watch') flags.watch = true;
    else if (a === '--serve') flags.serve = true;
    else if (a === '--no-open') flags.noOpen = true;
    else if (a.startsWith('--port=')) flags.port = Number(a.slice(7));
    else if (a === '--port') { const v = takeValue(); flags.port = v === null ? null : Number(v); }
    else if (a.startsWith('--interval=')) flags.interval = Number(a.slice(11));
    else if (a === '--interval') { const v = takeValue(); flags.interval = v === null ? null : Number(v); }
    else if (a === '--verbose' || a === '-v') flags.verbose = true;
    else if (a === '--debug') flags.debug = true;
    else if (a === '--show-hidden') flags.showHidden = true;
    else if (a.startsWith('--org=')) flags.org = a.slice(6);
    else if (a === '--org') flags.org = takeValue();
    else if (a.startsWith('--repo=')) flags.repo = a.slice(7);
    else if (a === '--repo') flags.repo = takeValue();
    else if (a.startsWith('--fav=')) flags.fav = a.slice(6);
    else if (a === '--fav') flags.fav = takeValue();
  }
  return flags;
}

// Effective poll interval: GitHub floor at 60 s. A provided value lower than
// that is raised to 60 (informative message on stderr).
function effectiveInterval(flags) {
  if (flags.interval === undefined) return POLL_SECONDS;
  if (!Number.isInteger(flags.interval)) {
    throw new Error('--interval requires an integer (seconds, e.g. --interval 120)');
  }
  if (flags.interval < POLL_SECONDS) {
    process.stderr.write(`gh notif: --interval ${flags.interval}s below the GitHub floor, raised to ${POLL_SECONDS}s\n`);
    return POLL_SECONDS;
  }
  return flags.interval;
}

// Ad-hoc scope requested on the command line (--org / --repo), or null.
async function resolveScope(gh, flags) {
  if (flags.org !== undefined && flags.repo !== undefined) {
    throw new Error('--org and --repo are mutually exclusive');
  }
  if (flags.org !== undefined) {
    if (!flags.org) throw new Error('--org requires a value (e.g. --org mapado)');
    return { type: 'org', value: flags.org };
  }
  if (flags.repo !== undefined) {
    const value = flags.repo ?? (await gh.currentRepo());
    if (!value) throw new Error('--repo without value: cannot determine the current repository (not in a git repo?)');
    return { type: 'repo', value };
  }
  return null;
}

// Resolves what we COLLECT and what we DISPLAY, in decreasing priority:
//   1. explicit --org/--repo → that scope alone, favorites out of play;
//   2. favorites exist       → union of favorites, filtered on the active favorite;
//   3. otherwise             → all of GitHub (historical behavior).
async function resolveScopes(gh, flags, prefs) {
  const adhoc = await resolveScope(gh, flags);
  const favorites = normalizeFavorites(prefs.favorites);
  if (adhoc) return { collectScope: adhoc, favorites, activeFav: null };

  let activeFav = activeFavoriteOf(prefs, favorites);
  if (flags.fav !== undefined) {
    if (!flags.fav) throw new Error('--fav requires a value (e.g. --fav mapado)');
    if (!favorites.includes(flags.fav)) {
      const known = favorites.length > 0 ? favorites.join(', ') : 'none (gh notif fav add <scope>)';
      throw new Error(`--fav ${flags.fav}: unknown favorite. Known favorites: ${known}`);
    }
    activeFav = flags.fav;
  }
  return { collectScope: favoriteScopes(favorites), favorites, activeFav };
}

// Subcommand `gh notif fav [add|rm|list] [scope]`: management of the favorites
// list (prefs-v1.json). Only `add` touches the network: a quick check
// that the scope exists on GitHub (org/user OR repo) — no right to pin
// a typo. Tri-state of scopeExists: false → hard refusal; null (network,
// rate-limit…) → fail-open with a warning, we don't block wrongly.
async function runFav(args) {
  const prefsFile = prefsPath();
  const prefs = loadPrefs(prefsFile);
  let favorites = normalizeFavorites(prefs.favorites);
  const [action, value] = args;

  if (action === 'add' || action === 'rm') {
    if (action === 'add') {
      const s = parseScope(value);
      if (s) {
        const exists = await makeGh().scopeExists(s);
        if (exists === false) {
          throw new Error(s.type === 'repo'
            ? `repository ${s.value} not found on GitHub`
            : `org/user ${s.value} not found on GitHub`);
        }
        if (exists === null) process.stderr.write(`gh notif fav: unable to verify « ${s.value} » (network?) — added anyway\n`);
      }
      favorites = addFavorite(favorites, value);
    } else {
      favorites = removeFavorite(favorites, value);
    }
    // ⚠️ mutate then rewrite the object IN FULL: savePrefs({favorites}) would lose
    // notify/theme (cf. ARCHITECTURE.md §persisted preferences).
    prefs.favorites = favorites;
    prefs.activeFav = activeFavoriteOf(prefs, favorites); // favorite removed → "all"
    savePrefs(prefsFile, prefs);
  } else if (action !== undefined && action !== 'list') {
    throw new Error(`fav: unknown action « ${action} » (add | rm | list)`);
  }

  if (favorites.length === 0) {
    process.stdout.write('No favorites. Add one: gh notif fav add mapado\n');
    return;
  }
  const active = activeFavoriteOf(prefs, favorites);
  process.stdout.write(`${favoritesBar(favorites, active)}\n`);
}

// Rows of a view (mine + others + hidden) for the "Checks by repo" section of
// --debug mode: lists the CI jobs and their state, marks the ignored ones.
function debugRows(shown) {
  return [...(shown.mine ?? []), ...(shown.others ?? []), ...(shown.hidden ?? [])];
}

async function runList(gh, { all, scope, showHidden, debug, favorites = [], activeFav = null, prefs = null, prefsFile = null }) {
  const hiddenFile = hiddenPath();
  const hidden = loadHidden(hiddenFile);
  const ignoredChecks = ignoredChecksOf(prefs); // CI blocklist per repo (verdict recomputation)
  const stop = startSpinner('Fetching PRs and notifications…');
  let data;
  try {
    const me = await gh.getCurrentUser();
    data = await collectPRs(gh, me, { all, scope, hidden, ignoredChecks });
  } finally {
    stop();
  }
  if (data.hiddenChanged) saveHidden(hiddenFile, hidden);

  // `data` stays RAW (union of favorites): it's what feeds the hiding.
  // `view()` only applies the active favorite filter at display time.
  let current = activeFav;
  const view = () => filterDataByScope(data, parseScope(current));

  // Outside TTY (pipe/redirection): print then hand back control, without interaction.
  if (!interactive()) {
    const shown = view();
    const vm = viewModel(shown, { showHidden });
    process.stdout.write(renderList({ mine: shown.mine, others: vm.rows, hiddenCount: shown.hiddenCount },
      { showHidden, hiddenFlags: vm.hiddenFlags }));
    if (debug) process.stdout.write(`\n${renderDebugText(shown.debug, { rows: debugRows(shown), ignoredChecks })}`);
    return;
  }

  // Interactive terminal: we stay alive to allow keyboard hiding.
  await runInteractive({
    draw: (hideMode, buffer) => {
      const shown = view();
      const vm = viewModel(shown, { showHidden });
      process.stdout.write('\x1b[2J\x1b[3J\x1b[H');
      process.stdout.write(renderList({ mine: shown.mine, others: vm.rows, hiddenCount: shown.hiddenCount },
        { showHidden, hiddenFlags: vm.hiddenFlags }));
      process.stdout.write(helpBanner(hideMode, buffer, ' · q to quit', favoritesBar(favorites, current)));
      if (debug) process.stdout.write(`\n${renderDebugText(shown.debug, { rows: debugRows(shown), ignoredChecks })}`);
    },
    rowsFor: () => viewModel(view(), { showHidden }).rows,
    onToggle: (row) => { toggleHidden(hidden, keyOf(row), data.notifications); saveHidden(hiddenFile, hidden); data = recompute(data, hidden); },
    // Local filter: no GitHub request, just a redraw + persistence.
    onCycleFav: () => {
      current = cycleFavorite(favorites, current);
      if (prefs && prefsFile) { prefs.activeFav = current; savePrefs(prefsFile, prefs); }
    },
  });
}

async function main(argv) {
  // Subcommand `fav`: handled separately, before parsing the flags.
  if (argv[2] === 'fav') {
    try {
      await runFav(argv.slice(3));
    } catch (err) {
      process.stderr.write(`gh notif fav: ${err.message}\n`);
      process.exit(1);
    }
    return;
  }

  const flags = parseArgs(argv);
  if (flags.help) { process.stdout.write(HELP); return; }
  const gh = makeGh();
  try {
    const prefsFile = prefsPath();
    const prefs = loadPrefs(prefsFile);
    const { collectScope, favorites, activeFav } = await resolveScopes(gh, flags, prefs);
    // `--fav` counts as an explicit choice: we persist it, otherwise --serve (which
    // re-reads prefs on its side) would ignore it. Mutate + rewrite in full (cf. prefs.js).
    if (flags.fav !== undefined && prefs.activeFav !== activeFav) {
      prefs.activeFav = activeFav;
      savePrefs(prefsFile, prefs);
    }
    const intervalSeconds = effectiveInterval(flags);
    if (flags.serve) {
      if (flags.port !== undefined && flags.port !== null && !Number.isInteger(flags.port)) {
        throw new Error('--port requires an integer (e.g. --port 7777)');
      }
      const me = await gh.getCurrentUser();
      // serve() re-reads the favorites from prefs itself: we only pass it the
      // eventual ad-hoc scope (Array ⇒ favorites mode, which it recomputes).
      serve({ gh, me, scope: Array.isArray(collectScope) ? null : collectScope, all: flags.all, port: flags.port ?? 7777, intervalSeconds, open: !flags.noOpen });
    } else if (flags.watch) {
      await runWatch(gh, { scope: collectScope, verbose: flags.verbose, showHidden: flags.showHidden, debug: flags.debug, intervalSeconds, favorites, activeFav, prefs, prefsFile });
    } else {
      await runList(gh, { all: flags.all, scope: collectScope, showHidden: flags.showHidden, debug: flags.debug, favorites, activeFav, prefs, prefsFile });
    }
  } catch (err) {
    process.stderr.write(`gh notif: ${err.message}\n`);
    process.exit(1);
  }
}

main(process.argv);

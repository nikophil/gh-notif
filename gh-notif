#!/usr/bin/env node
import { existsSync } from 'node:fs';
import { makeGh } from './src/github.js';
import { collectNotifications, collectPending } from './src/collect.js';
import { renderList } from './src/render.js';
import { sendNotification, watchEventLine } from './src/notify.js';
import { statePath, loadState, saveState, isNew, markSeen } from './src/state.js';

const POLL_SECONDS = 60;
const sleep = (s) => new Promise((r) => setTimeout(r, s * 1000));
const now = () => new Date().toLocaleTimeString('fr-FR');

// Compte à rebours réécrit en place jusqu'au prochain poll (uniquement en TTY).
async function countdown(seconds) {
  if (!process.stdout.isTTY) {
    await sleep(seconds);
    return;
  }
  for (let n = seconds; n > 0; n--) {
    process.stdout.write(`\r\x1b[2m⏳ prochain check dans ${String(n).padStart(2)}s…\x1b[0m\x1b[K`);
    await sleep(1);
  }
  process.stdout.write('\r\x1b[K'); // efface la ligne du compteur avant le poll
}

async function runWatch(gh) {
  const me = await gh.getCurrentUser();
  const path = statePath();
  let primed = existsSync(path); // un état existe déjà : on notifie normalement
  const state = loadState(path);
  process.stdout.write(`gh notif --watch : surveillance toutes les ${POLL_SECONDS}s (Ctrl-C pour arrêter)\n`);
  for (;;) {
    try {
      const items = await collectNotifications(gh, me, { all: false });
      if (!primed) {
        // Premier run : on enregistre le backlog existant sans alerter,
        // pour ne notifier que les évènements survenant après le démarrage.
        for (const item of items) markSeen(state, item);
        saveState(path, state);
        primed = true;
        process.stdout.write(`(premier run : ${items.length} notification(s) existante(s) marquée(s) comme vues, sans alerte)\n`);
      } else {
        const fresh = items.filter((i) => isNew(state, i));
        for (const item of fresh) {
          sendNotification(item);
          process.stdout.write(`${watchEventLine(item, now())}\n`);
          markSeen(state, item);
        }
        if (fresh.length > 0) saveState(path, state);
      }
    } catch (err) {
      process.stderr.write(`gh notif --watch: ${err.message}\n`);
    }
    await countdown(POLL_SECONDS);
  }
}

const HELP = `gh notif — notifications GitHub filtrées

Usage:
  gh notif            Liste les notifications pertinentes + reviews en attente
  gh notif --all      Inclut les notifications déjà lues
  gh notif --watch    Poll en continu (compte à rebours) et pousse des notifs
                      desktop, en loggant chaque notif + son déclencheur
  gh notif --help     Affiche cette aide
`;

async function runList(gh, { all }) {
  const me = await gh.getCurrentUser();
  const [items, pending] = await Promise.all([
    collectNotifications(gh, me, { all }),
    collectPending(gh),
  ]);
  process.stdout.write(renderList(items, pending));
}

async function main(argv) {
  const args = new Set(argv.slice(2));
  if (args.has('--help') || args.has('-h')) { process.stdout.write(HELP); return; }
  const gh = makeGh();
  try {
    if (args.has('--watch')) {
      await runWatch(gh);
    } else {
      await runList(gh, { all: args.has('--all') });
    }
  } catch (err) {
    process.stderr.write(`gh notif: ${err.message}\n`);
    process.exit(1);
  }
}

main(process.argv);

#!/usr/bin/env node
import { makeGh } from './src/github.js';
import { favoritesBar } from './src/render.js';
import { prefsPath, loadPrefs, savePrefs } from './src/prefs.js';
import {
  parseScope, normalizeFavorites, addFavorite, removeFavorite,
  favoriteScopes, activeFavoriteOf,
} from './src/favorites.js';
import { serve } from './src/serve.js';

const POLL_SECONDS = 60;

const HELP = `gh notif — filtered GitHub notifications (local web dashboard)

Usage:
  gh notif                   Launch the local web page (default :7777, opens the browser)
  gh notif --port N          Serve on another port
  gh notif --no-open         Do not open the browser (the URL stays printed)
  gh notif --all             Include already-read notifications
  gh notif --interval N      Seconds between two polls (floor 60)
  gh notif --org <org>       Limit to one organization
  gh notif --repo [o/r]      Limit to one repository (no value = current repo)
  gh notif --fav <scope>     Start on this favorite (must be in the list)
  gh notif --help            Show this help

Favorites (pinned scopes) :
  gh notif fav list          List favorites (⭐ = the one shown)
  gh notif fav add <scope>   Pin an org (symfony) or a repository (owner/repo)
  gh notif fav rm <scope>    Remove a favorite

As soon as a favorite exists, collection covers the UNION of favorites — so the
desktop notifications of all of them arrive continuously — and only the active
favorite is shown (chips in the header). Switching favorite costs no GitHub request.

--org and --repo are mutually exclusive and take precedence over favorites
(then ignored, shown greyed out).

The web page auto-refreshes on its own (~60 s), pushes desktop notifications on
new events, lets you hide/restore others' PRs (🙈), switch theme, and exposes a
/debug page (🐛 in the header) with the per-thread classification verdict and the
« Checks by repo » section to configure the per-repo CI blocklist.

Ignored CI jobs: so that an unimportant job (e.g. a label reminder) no longer
turns a PR to ❌, tick it in the /debug page (or add it to the repo blocklist in
prefs-v1.json: "ignoredChecks": { "owner/repo": ["exact check name"] }). The CI
verdict is then recomputed without that job, with no GitHub call.

Deprecated (accepted, no longer needed): --serve (now the default), --watch.
`;

// Parse the arguments. repo: undefined=absent, null=given without value (current
// repo), string=value. org: undefined=absent, null=given without value
// (error, value required), string=value. --serve is accepted but a no-op (serving
// is now the default behavior); other legacy terminal flags are simply ignored.
function parseArgs(argv) {
  const args = argv.slice(2);
  const flags = { all: false, port: undefined, interval: undefined, help: false, org: undefined, repo: undefined, fav: undefined, noOpen: false };
  for (let i = 0; i < args.length; i++) {
    const a = args[i];
    const takeValue = () => {
      const next = args[i + 1];
      if (next && !next.startsWith('-')) { i += 1; return next; }
      return null;
    };
    if (a === '--help' || a === '-h') flags.help = true;
    else if (a === '--all') flags.all = true;
    else if (a === '--serve') { /* deprecated: serving is now the default */ }
    else if (a === '--no-open') flags.noOpen = true;
    else if (a.startsWith('--port=')) flags.port = Number(a.slice(7));
    else if (a === '--port') { const v = takeValue(); flags.port = v === null ? null : Number(v); }
    else if (a.startsWith('--interval=')) flags.interval = Number(a.slice(11));
    else if (a === '--interval') { const v = takeValue(); flags.interval = v === null ? null : Number(v); }
    else if (a.startsWith('--org=')) flags.org = a.slice(6);
    else if (a === '--org') flags.org = takeValue();
    else if (a.startsWith('--repo=')) flags.repo = a.slice(7);
    else if (a === '--repo') flags.repo = takeValue();
    else if (a.startsWith('--fav=')) flags.fav = a.slice(6);
    else if (a === '--fav') flags.fav = takeValue();
  }
  return flags;
}

// Effective poll interval: GitHub floor at 60 s. A provided value lower than
// that is raised to 60 (informative message on stderr).
function effectiveInterval(flags) {
  if (flags.interval === undefined) return POLL_SECONDS;
  if (!Number.isInteger(flags.interval)) {
    throw new Error('--interval requires an integer (seconds, e.g. --interval 120)');
  }
  if (flags.interval < POLL_SECONDS) {
    process.stderr.write(`gh notif: --interval ${flags.interval}s below the GitHub floor, raised to ${POLL_SECONDS}s\n`);
    return POLL_SECONDS;
  }
  return flags.interval;
}

// Ad-hoc scope requested on the command line (--org / --repo), or null.
async function resolveScope(gh, flags) {
  if (flags.org !== undefined && flags.repo !== undefined) {
    throw new Error('--org and --repo are mutually exclusive');
  }
  if (flags.org !== undefined) {
    if (!flags.org) throw new Error('--org requires a value (e.g. --org symfony)');
    return { type: 'org', value: flags.org };
  }
  if (flags.repo !== undefined) {
    const value = flags.repo ?? (await gh.currentRepo());
    if (!value) throw new Error('--repo without value: cannot determine the current repository (not in a git repo?)');
    return { type: 'repo', value };
  }
  return null;
}

// Resolves what we COLLECT and what we DISPLAY, in decreasing priority:
//   1. explicit --org/--repo → that scope alone, favorites out of play;
//   2. favorites exist       → union of favorites, filtered on the active favorite;
//   3. otherwise             → all of GitHub (historical behavior).
async function resolveScopes(gh, flags, prefs) {
  const adhoc = await resolveScope(gh, flags);
  const favorites = normalizeFavorites(prefs.favorites);
  if (adhoc) return { collectScope: adhoc, favorites, activeFav: null };

  let activeFav = activeFavoriteOf(prefs, favorites);
  if (flags.fav !== undefined) {
    if (!flags.fav) throw new Error('--fav requires a value (e.g. --fav symfony)');
    if (!favorites.includes(flags.fav)) {
      const known = favorites.length > 0 ? favorites.join(', ') : 'none (gh notif fav add <scope>)';
      throw new Error(`--fav ${flags.fav}: unknown favorite. Known favorites: ${known}`);
    }
    activeFav = flags.fav;
  }
  return { collectScope: favoriteScopes(favorites), favorites, activeFav };
}

// Subcommand `gh notif fav [add|rm|list] [scope]`: management of the favorites
// list (prefs-v1.json). Only `add` touches the network: a quick check
// that the scope exists on GitHub (org/user OR repo) — no right to pin
// a typo. Tri-state of scopeExists: false → hard refusal; null (network,
// rate-limit…) → fail-open with a warning, we don't block wrongly.
async function runFav(args) {
  const prefsFile = prefsPath();
  const prefs = loadPrefs(prefsFile);
  let favorites = normalizeFavorites(prefs.favorites);
  const [action, value] = args;

  if (action === 'add' || action === 'rm') {
    if (action === 'add') {
      const s = parseScope(value);
      if (s) {
        const exists = await makeGh().scopeExists(s);
        if (exists === false) {
          throw new Error(s.type === 'repo'
            ? `repository ${s.value} not found on GitHub`
            : `org/user ${s.value} not found on GitHub`);
        }
        if (exists === null) process.stderr.write(`gh notif fav: unable to verify « ${s.value} » (network?) — added anyway\n`);
      }
      favorites = addFavorite(favorites, value);
    } else {
      favorites = removeFavorite(favorites, value);
    }
    // ⚠️ mutate then rewrite the object IN FULL: savePrefs({favorites}) would lose
    // notify/theme (cf. ARCHITECTURE.md §persisted preferences).
    prefs.favorites = favorites;
    prefs.activeFav = activeFavoriteOf(prefs, favorites); // favorite removed → "all"
    savePrefs(prefsFile, prefs);
  } else if (action !== undefined && action !== 'list') {
    throw new Error(`fav: unknown action « ${action} » (add | rm | list)`);
  }

  if (favorites.length === 0) {
    process.stdout.write('No favorites. Add one: gh notif fav add symfony\n');
    return;
  }
  const active = activeFavoriteOf(prefs, favorites);
  process.stdout.write(`${favoritesBar(favorites, active)}\n`);
}

async function main(argv) {
  // Subcommand `fav`: handled separately, before parsing the flags.
  if (argv[2] === 'fav') {
    try {
      await runFav(argv.slice(3));
    } catch (err) {
      process.stderr.write(`gh notif fav: ${err.message}\n`);
      process.exit(1);
    }
    return;
  }

  const flags = parseArgs(argv);
  if (flags.help) { process.stdout.write(HELP); return; }
  const gh = makeGh();
  try {
    const prefsFile = prefsPath();
    const prefs = loadPrefs(prefsFile);
    const { collectScope, activeFav } = await resolveScopes(gh, flags, prefs);
    // `--fav` counts as an explicit choice: we persist it so serve() (which
    // re-reads prefs on its side) picks it up. Mutate + rewrite in full (cf. prefs.js).
    if (flags.fav !== undefined && prefs.activeFav !== activeFav) {
      prefs.activeFav = activeFav;
      savePrefs(prefsFile, prefs);
    }
    const intervalSeconds = effectiveInterval(flags);
    if (flags.port !== undefined && flags.port !== null && !Number.isInteger(flags.port)) {
      throw new Error('--port requires an integer (e.g. --port 7777)');
    }
    const me = await gh.getCurrentUser();
    // serve() re-reads the favorites from prefs itself: we only pass it the
    // eventual ad-hoc scope (Array ⇒ favorites mode, which it recomputes).
    serve({ gh, me, scope: Array.isArray(collectScope) ? null : collectScope, all: flags.all, port: flags.port ?? 7777, intervalSeconds, open: !flags.noOpen });
  } catch (err) {
    process.stderr.write(`gh notif: ${err.message}\n`);
    process.exit(1);
  }
}

main(process.argv);
